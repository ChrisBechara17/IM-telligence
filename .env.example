# ------------------------------------------------------------------
# Backend (Express on Render) — copy to `.env` for local development.
# ------------------------------------------------------------------

# Postgres connection string from Vercel Postgres (Neon).
# Vercel/Neon dashboard → your database → ".env.local" / connection string.
DATABASE_URL=postgres://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Password for the /admin dashboard.
ADMIN_PASSWORD=change-me

# Public origin of THIS backend — used to build absolute image URLs.
# Local: leave blank (the Vite proxy handles /uploads).
# Render: set to your service URL, e.g. https://imt-api.onrender.com
PUBLIC_URL=

# Comma-separated allowed frontend origins for CORS. Blank = allow all.
# Prod example: https://your-site.vercel.app
CORS_ORIGIN=

# Where uploaded images are written. Render: point at a mounted disk, e.g. /var/data/uploads
# UPLOADS_DIR=/var/data/uploads

# ------------------------------------------------------------------
# Frontend (Vite on Vercel)
# ------------------------------------------------------------------
# Origin of the deployed backend. Local: leave unset (Vite proxy is used).
# Vercel: set to your Render URL, e.g. https://imt-api.onrender.com
# VITE_API_URL=
